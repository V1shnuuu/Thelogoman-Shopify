{% comment %}
  Custom 3D Automotive Stickers Product Page Section
  - Product variant selection
  - File upload for custom designs
  - Line item property data storage
{% endcomment %}

{%- assign product = all_products[section.settings.product] -%}
{%- if product == empty -%}
  {%- assign product = all_products['custom-3d-sticker'] -%}
{%- endif -%}
{%- if product == empty -%}
  {%- assign product = all_products['3d-automotive-stickers'] -%}
{%- endif -%}
{%- if product == empty -%}
  {%- assign product = all_products['3d-car-hanging'] -%}
{%- endif -%}
{%- if product == empty -%}
  {%- assign product = all_products['3d-mobile-stickers'] -%}
{%- endif -%}

<div class="custom-automotive-stickers">
  <div class="container">
    <div class="row">
      <!-- Product Image -->
      <div class="col-md-6 product-image-section">
        <div class="product-image-wrapper">
          {%- if section.settings.custom_image != blank -%}
            <img 
              src="{{ section.settings.custom_image | img_url: '600x600' }}" 
              alt="{{ product.title | default: 'Custom 3D Automotive Stickers' }}"
              class="img-fluid product-main-image"
            >
          {%- else -%}
            <img 
              src="{{ 'custom-3d-automotive-sticker.jpg' | asset_img_url: '600x600' }}" 
              alt="{{ product.title | default: 'Custom 3D Automotive Stickers' }}"
              class="img-fluid product-main-image"
            >
          {%- endif -%}
        </div>
      </div>

      <!-- Product Details & Form -->
      <div class="col-md-6 product-details-section">
        <h1 class="product-title">{{ product.title }}</h1>
        
        {% if product.description %}
          <div class="product-description">
            {{ product.description }}
          </div>
        {% endif %}

        <!-- Product Form -->
        <form id="product-form" action="/cart/add" method="post" enctype="multipart/form-data" class="product-form">
          {% if product == empty %}
            <div style="background: rgba(255, 75, 75, 0.15); border: 1px solid #ff4b4b; color: #ff6b6b; padding: 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; line-height: 1.4;">
              <strong>⚠️ Product Link Required:</strong> No custom sticker product is currently linked to this page. Please open your Shopify Theme Editor (Customizer), select this section, and pick your custom product in the settings!
            </div>
          {% endif %}
          <input type="hidden" name="id" id="hidden-variant-id" value="{{ product.selected_or_first_available_variant.id | default: product.variants.first.id }}">
          
          <!-- Variant Selection -->
          {% if product != empty and product.variants.size > 0 %}
            <div class="variant-selector-group">
              <label for="variant-selector" class="form-label">Select Sticker Variant:</label>
              <select 
                id="variant-selector" 
                class="form-select variant-select"
              >
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" {% if variant == product.selected_or_first_available_variant or variant == product.variants.first %}selected{% endif %}>
                    {{ variant.title }} - {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% endif %}

          <!-- File Upload Section -->
          <div class="file-upload-group">
            <label for="design-file" class="form-label">Upload Your Custom Design (Optional):</label>
            <div class="file-upload-wrapper">
              <input 
                type="file" 
                id="design-file" 
                name="properties[_Custom Design]" 
                accept=".png,.jpg,.jpeg,.pdf,.ai,.psd"
                class="form-control file-input"
              >
              <small class="form-text text-muted">
                Accepted formats: PNG, JPG, PDF, AI, PSD (Max 10MB)
              </small>
              <div id="file-info" class="mt-2 file-info"></div>
            </div>
          </div>

          <!-- Additional Properties -->
          <div class="properties-group">
            <div class="form-group">
              <label for="sticker-size" class="form-label">Sticker Size Preference:</label>
              <input 
                type="text" 
                id="sticker-size" 
                name="properties[Sticker Size]" 
                placeholder="e.g., 3 inches, 6 inches"
                class="form-control"
              >
            </div>

            <div class="form-group">
              <label for="special-instructions" class="form-label">Special Instructions:</label>
              <textarea 
                id="special-instructions" 
                name="properties[Special Instructions]" 
                placeholder="Any special requests for your stickers?"
                class="form-control"
                rows="4"
              ></textarea>
            </div>
          </div>

          <!-- Price & Quantity -->
                    <div class="product-price-quantity" style="border: none; padding: 0; margin: 0;">
            <div class="price-section" style="margin-bottom: 20px;">
              <span id="product-price" class="product-price" style="font-size: 20px; font-weight: 700; color: #fff;">{{ product.selected_or_first_available_variant.price | money }}</span>
            </div>
            
            <div class="product-actions" style="display: flex; gap: 12px; width: 100%; margin-top: 15px;">
              <div class="quantity-wrapper" style="display: flex; align-items: center; background: #252525; width: 130px; justify-content: space-between;">
                <button type="button" class="qty-btn" id="qty-minus" style="background: transparent; border: none; color: #fff; font-size: 20px; padding: 12px 16px; cursor: pointer;">&minus;</button>
                <input type="number" class="qty-input" name="quantity" id="qty-input" min="1" value="1" style="background: transparent; border: none; color: #fff; width: 40px; text-align: center; font-size: 16px; font-weight: 600; padding: 0; -moz-appearance: textfield;">
                <button type="button" class="qty-btn" id="qty-plus" style="background: transparent; border: none; color: #fff; font-size: 20px; padding: 12px 16px; cursor: pointer;">+</button>
              </div>
              <button type="submit" class="btn-add-to-cart" {% unless product.available %}disabled{% endunless %} style="flex-grow: 1; background: #0a0a0a; color: #fff; border: none; padding: 16px 20px; font-size: 16px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; cursor: pointer;">
                {% if product.available %}ADD TO CART{% else %}OUT OF STOCK{% endif %}
              </button>
            </div>
          </div>
        </form>

        <!-- Product Details Tabs -->
        {% if product.description or product.metafields.custom.specifications %}
          <div class="product-details-tabs mt-5">
            <nav class="nav nav-tabs" role="tablist">
              <button class="nav-link active" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button">Description</button>
              {% if product.metafields.custom.specifications %}
                <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button">Specifications</button>
              {% endif %}
            </nav>
            <div class="tab-content">
              <div class="tab-pane fade show active" id="description">
                {{ product.description }}
              </div>
              {% if product.metafields.custom.specifications %}
                <div class="tab-pane fade" id="specs">
                  {{ product.metafields.custom.specifications }}
                </div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% render 'custom-cross-banner' %}

<style>
  .custom-automotive-stickers {
    padding: 10px 0 40px;
  }

  .custom-automotive-stickers .product-image-wrapper {
    margin-bottom: 30px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .custom-automotive-stickers .product-title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #1a1a1a;
  }

  .custom-automotive-stickers .product-description {
    font-size: 16px;
    line-height: 1.6;
    color: #666;
    margin-bottom: 30px;
  }

  .custom-automotive-stickers .variant-selector-group,
  .custom-automotive-stickers .file-upload-group,
  .custom-automotive-stickers .properties-group {
    margin-bottom: 25px;
  }

  .custom-automotive-stickers .form-label {
    font-weight: 600;
    color: #1a1a1a;
    margin-bottom: 10px;
    display: block;
  }

  .custom-automotive-stickers .form-control,
  .custom-automotive-stickers .form-select {
    border: 1px solid #ddd;
    padding: 10px 12px;
    border-radius: 4px;
    font-size: 14px;
  }

  .custom-automotive-stickers .form-control:focus,
  .custom-automotive-stickers .form-select:focus {
    border-color: #0066cc;
    box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
  }

  .custom-automotive-stickers .file-info {
    font-size: 13px;
    color: #666;
  }

  .custom-automotive-stickers .product-price-quantity {
    display: flex;
    gap: 40px;
    align-items: center;
    margin: 30px 0;
    padding: 20px 0;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
  }

  .custom-automotive-stickers .price-section {
    flex: 1;
  }

  .custom-automotive-stickers .price-label {
    font-weight: 600;
    color: #666;
    margin-right: 10px;
  }

  .custom-automotive-stickers .product-price {
    font-size: 24px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .custom-automotive-stickers .quantity-section {
    width: 150px;
  }

  .custom-automotive-stickers .quantity-input {
    width: 100%;
    text-align: center;
  }

  .custom-automotive-stickers .btn-add-to-cart {
    width: 100%;
    padding: 14px;
    font-size: 16px;
    font-weight: 600;
    background-color: #0066cc;
    border: none;
    color: white;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.3s;
  }

  .custom-automotive-stickers .btn-add-to-cart:hover {
    background-color: #0052a3;
  }

  .custom-automotive-stickers .btn-add-to-cart:disabled {
    background-color: #ccc;
    cursor: not-allowed;
  }

  .custom-automotive-stickers .product-details-tabs {
    border-top: 1px solid #eee;
    padding-top: 30px;
  }

  .custom-automotive-stickers .nav-tabs {
    border-bottom: 2px solid #eee;
  }

  .custom-automotive-stickers .nav-tabs .nav-link {
    border: none;
    color: #666;
    font-weight: 500;
    padding-bottom: 10px;
    margin-bottom: -2px;
    border-bottom: 2px solid transparent;
  }

  .custom-automotive-stickers .nav-tabs .nav-link.active {
    color: #0066cc;
    border-bottom-color: #0066cc;
  }

  .custom-automotive-stickers .tab-content {
    padding-top: 20px;
  }

  @media (max-width: 768px) {
    .custom-automotive-stickers .product-price-quantity {
      flex-direction: column;
      gap: 20px;
    }

    .custom-automotive-stickers .quantity-section {
      width: 100%;
    }

    .custom-automotive-stickers .product-title {
      font-size: 24px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    console.log("Custom page JS loaded");

    const qtyMinusSection = document.getElementById('qty-minus');
    const qtyPlusSection = document.getElementById('qty-plus');
    const qtyInputSection = document.getElementById('qty-input');
    
    if (qtyMinusSection && qtyPlusSection && qtyInputSection) {
      qtyMinusSection.addEventListener('click', () => {
        let val = parseInt(qtyInputSection.value) || 1;
        if (val > 1) qtyInputSection.value = val - 1;
      });
      qtyPlusSection.addEventListener('click', () => {
        let val = parseInt(qtyInputSection.value) || 1;
        qtyInputSection.value = val + 1;
      });
    }

    const variantSelect = document.getElementById('variant-selector');
    const hiddenVariantIdInput = document.getElementById('hidden-variant-id');
    const priceDisplay = document.getElementById('product-price');
    const productForm = document.getElementById('product-form');

    // Update variant ID and price when dropdown changes
    if (variantSelect && hiddenVariantIdInput) {
      variantSelect.addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const selectedVariantId = selectedOption.value;
        hiddenVariantIdInput.value = selectedVariantId;
        console.log("Selected variant ID:", selectedVariantId);

        const price = selectedOption.getAttribute('data-price');
        if (priceDisplay && price) {
          priceDisplay.textContent = price;
        }
      });
    }

    // Intercept form submission for validation and logging
    if (productForm) {
      productForm.addEventListener('submit', function(e) {
        // Validation
        const variantId = hiddenVariantIdInput ? hiddenVariantIdInput.value : '';
        if (!variantId) {
          e.preventDefault();
          alert('Error: No variant selected.');
          return;
        }
        if (isNaN(variantId)) {
          e.preventDefault();
          alert('Error: Selected variant ID is not numeric.');
          return;
        }

        console.log("Selected variant ID:", variantId);

        const formData = new FormData(productForm);

        // Debug logging of FormData entries
        console.log("FormData entries:");
        for (let pair of formData.entries()) {
          console.log(pair[0] + ': ' + pair[1]);
        }

        if (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost') {
          productForm.action = 'https://thelogoman-2.myshopify.com/cart/add';
        }

        // Native form submission will execute seamlessly, redirecting to /cart
      });
    }

    // File upload handling
    const designFile = document.getElementById('design-file');
    const fileInfo = document.getElementById('file-info');
    
    if (designFile) {
      designFile.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
          const sizeMB = (file.size / (1024 * 1024)).toFixed(2);
          fileInfo.innerHTML = `<strong>File:</strong> ${file.name} (${sizeMB} MB)`;
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Custom Auto Stickers",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Select Custom Product",
      "info": "Choose the product whose variants and details should be sold on this custom page."
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom Page Image",
      "info": "Select a custom image to override the default product image on this page."
    }
  ],
  "presets": [
    {
      "name": "Custom Automotive Stickers"
    }
  ]
}
{% endschema %}
