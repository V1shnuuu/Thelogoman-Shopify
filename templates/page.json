      "settings": {
        "custom_liquid": "{%- assign product_handle = 'custom-3d-keychain' -%}\n{%- assign heading_text = 'Customize Your Keychain' -%}\n{%- assign hero_image = 'https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?auto=format&fit=crop&w=1200&q=80' -%}\n\n{%- if page.handle contains 'keychain' -%}\n  {%- assign product_handle = 'custom-3d-keychain' -%}\n  {%- assign heading_text = 'Customize Your Keychain' -%}\n  {%- assign hero_image = 'custom-3d-keychain.jpg' | asset_img_url: '600x600' -%}\n{%- elsif page.handle contains 'hanging' or page.handle contains 'car-hanging' -%}\n  {%- assign product_handle = 'custom-3d-car-hanging' -%}\n  {%- assign heading_text = 'Customize Your Hanging' -%}\n  {%- assign hero_image = 'custom-3d-car-hanging.png' | asset_img_url: '600x600' -%}\n{%- elsif page.handle contains 'automotive' -%}\n  {%- assign product_handle = 'custom-3d-sticker' -%}\n  {%- assign heading_text = 'Customize Your Sticker' -%}\n  {%- assign hero_image = 'custom-3d-automotive-sticker.jpg' | asset_img_url: '600x600' -%}\n{%- elsif page.handle contains 'mobile' -%}\n  {%- assign product_handle = 'custom-3d-mobile-sticker' -%}\n  {%- assign heading_text = 'Customize Your Mobile Sticker' -%}\n  {%- assign hero_image = 'custom-3d-mobile-sticker.png' | asset_img_url: '600x600' -%}\n{%- elsif page.handle contains 'clothing' -%}\n  {%- assign product_handle = page.handle -%}\n  {%- assign heading_text = 'Custom T-shirt' -%}\n  {%- assign hero_image = 'custom-clothing.jpg' | asset_img_url: '600x600' -%}\n{%- endif -%}\n\n{%- assign product = all_products[product_handle] -%}\n{%- if product == empty -%}\n  {%- if page.handle contains 'hanging' -%}\n    {%- assign product = all_products['3d-car-hanging'] -%}\n  {%- elsif page.handle contains 'automotive' -%}\n    {%- assign product = all_products['custom-3d-sticker'] -%}\n  {%- elsif page.handle contains 'mobile' -%}\n    {%- assign product = all_products['custom-3d-mobile-sticker'] -%}\n  {%- elsif page.handle contains 'clothing' -%}\n    {%- assign product = all_products['custom-clothing-accessories'] -%}\n    {%- if product == empty -%}\n      {%- assign product = all_products['custom-clothing-and-accessories'] -%}\n    {%- endif -%}\n  {%- else -%}\n    {%- assign product = all_products['custom-3d-keychain'] -%}\n  {%- endif -%}\n{%- endif -%}\n<style>\n\n.custom-order {\n  max-width: 1400px;\n  margin: 40px auto; \n  padding: 0 20px;\n  display: grid;\n  grid-template-columns: 1fr 1fr; \n  gap: 40px; \n  font-family: inherit;\n  color: #fff;\n}\n\n\n.image-container {\n  display: flex;\n  justify-content: center;\n  align-items: flex-start;\n  width: 100%;\n  margin-top: 10px;\n}\n.custom-order img.main-img {\n  width: auto;\n  max-width: 100%;\n  height: auto;\n  max-height: 440px; \n  border: 1px solid #333;\n  border-radius: 16px;\n  display: block;\n  object-fit: contain; \n  box-shadow: 0 4px 25px rgba(0, 0, 0, 0.5);\n}\n\n\n.custom-order h1 {\n  font-size: 38px; \n  margin: 0 0 30px; \n  font-weight: 800;\n  line-height: 1.1;\n  letter-spacing: -1px;\n  text-transform: uppercase;\n}\n\n.form-row {\n  display: flex;\n  align-items: center;\n  margin-bottom: 20px;\n}\n.form-row label.row-label {\n  width: 150px; \n  flex-shrink: 0;\n  font-weight: 600;\n  color: #ddd;\n  font-size: 16px;\n}\n\n.form-row select,\n.form-row input[type=\"text\"],\n.form-row input[type=\"number\"],\n.form-row input[type=\"file\"] {\n  flex-grow: 1;\n  width: 100%;\n  padding: 14px 16px; \n  border: 1px solid #444;\n  border-radius: 6px;\n  background: #1a1a1a;\n  color: #fff;\n  font-size: 15px;\n  cursor: pointer;\n}\n\n.form-row input[readonly] {\n  cursor: default;\n  background: #222;\n  border-color: #555;\n  color: #aaa;\n}\n\n.form-row input[type=\"file\"]::file-selector-button {\n  background: #333;\n  color: #fff;\n  border: none;\n  padding: 6px 12px;\n  border-radius: 4px;\n  margin-right: 12px;\n  cursor: pointer;\n}\n\n.time-btn {\n  display: inline-block;\n  padding: 10px 24px;\n  border: 1px solid #555; \n  border-radius: 6px;\n  color: #fff; \n  background: rgba(255, 255, 255, 0.05); \n}\n\n.custom-order .production-buttons {\n  display: flex;\n  gap: 12px;\n  flex-wrap: wrap;\n  flex-grow: 1;\n}\n\n.custom-order .production-option {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: auto;\n  min-width: 160px;\n  padding: 10px 18px;\n  border: 1px solid rgba(255,255,255,0.2);\n  border-radius: 6px;\n  background: rgba(255,255,255,0.05);\n  color: #fff;\n  cursor: pointer;\n  transition: background 0.2s, border-color 0.2s;\n  font-weight: 600;\n  font-size: 15px;\n  text-transform: none;\n  box-shadow: none;\n}\n\n.custom-order .production-option.active {\n  background: #00E676;\n  border-color: #00E676;\n  color: #000;\n}\n\n.custom-order .production-option:focus-visible {\n  outline: 2px solid #fff;\n  outline-offset: 2px;\n}\n\n\n.custom-order .size-buttons {\n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n  flex-grow: 1;\n}\n.custom-order .size-option {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 50px;\n  height: 50px;\n  border: 1px solid rgba(255,255,255,0.2);\n  border-radius: 8px;\n  background: rgba(255,255,255,0.05);\n  color: #fff;\n  cursor: pointer;\n  transition: background 0.2s, border-color 0.2s, color 0.2s;\n  font-weight: 600;\n  font-size: 15px;\n}\n.custom-order .size-option.active {\n  background: #00E676;\n  border-color: #00E676;\n  color: #000;\n}\n.custom-order .size-option:focus-visible {\n  outline: 2px solid #fff;\n  outline-offset: 2px;\n}\n\n.inline-preview {\n  display: none; \n  margin: 0 0 24px 150px; \n  padding: 12px;\n  background: #1a1a1a;\n  border: 1px dashed #555;\n  border-radius: 8px;\n}\n\n\n.custom-order .product-actions {\n  display: flex;\n  gap: 12px;\n  width: 100%;\n  margin-top: 30px;\n}\n.custom-order .quantity-wrapper {\n  display: flex;\n  align-items: center;\n  background: #252525;\n  width: 130px;\n  justify-content: space-between;\n}\n.custom-order .qty-btn {\n  background: transparent;\n  border: none;\n  color: #fff;\n  font-size: 20px;\n  padding: 12px 16px;\n  cursor: pointer;\n  transition: opacity 0.2s;\n}\n.custom-order .qty-btn:hover {\n  opacity: 0.7;\n}\n.custom-order .qty-input {\n  background: transparent;\n  border: none;\n  color: #fff;\n  width: 40px;\n  text-align: center;\n  font-size: 16px;\n  font-weight: 600;\n  padding: 0;\n  -moz-appearance: textfield;\n}\n.custom-order .qty-input::-webkit-outer-spin-button,\n.custom-order .qty-input::-webkit-inner-spin-button {\n  -webkit-appearance: none;\n  margin: 0;\n}\n.custom-order .add-to-cart-btn {\n  flex-grow: 1;\n  background: #0a0a0a;\n  color: #fff;\n  border: none;\n  padding: 16px 20px;\n  font-size: 16px;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  cursor: pointer;\n  transition: background 0.2s;\n}\n.custom-order .add-to-cart-btn:hover {\n  background: #1a1a1a;\n}\n\n@media(max-width:990px) {\n  .custom-order { grid-template-columns: 1fr; }\n  .image-container { margin-top: 0; }\n  .form-row { flex-direction: column; align-items: flex-start; }\n  .inline-preview { margin-left: 0; }\n}\n</style>\n\n<div class=\"custom-order\">\n  <div class=\"image-container\">\n    <img class=\"main-img\" id=\"main-hero-image\" src=\"{{ hero_image }}\">\n  </div>\n  <div>\n    <h1>{{ heading_text }}</h1>\n    <form id=\"product-form\" action=\"/cart/add\" method=\"post\" enctype=\"multipart/form-data\">\n      {% if product == empty %}\n        <div style=\"background: rgba(255, 75, 75, 0.15); border: 1px solid #ff4b4b; color: #ff6b6b; padding: 16px; border-radius: 8px; margin-bottom: 20px; font-size: 14px; line-height: 1.4;\">\n          <strong>⚠️ Product Link Required:</strong> No custom product is currently active or matched to this template. Please verify that a product with the handle <code>custom-3d-car-hanging</code> or <code>custom-3d-sticker</code> is active in your products list.\n        </div>\n      {% endif %}\n      <input type=\"hidden\" name=\"id\" id=\"hidden-variant-id\" value=\"{{ product.selected_or_first_available_variant.id | default: product.variants.first.id }}\">\n      <div class=\"form-row\"><label class=\"row-label\">Size</label>{% if page.handle contains 'car-hanging' %}<input type=\"text\" name=\"properties[Size]\" value=\"11.3 x 7.5 x 0.7 cm\" readonly class=\"form-control\">{% elsif page.handle contains 'mobile' %}<input type=\"text\" name=\"properties[Size]\" value=\"3.5 × 1.7 × 0.3 cm\" readonly class=\"form-control\">{% elsif page.handle contains 'keychain' %}<input type=\"text\" name=\"properties[Size]\" value=\"3 × 7 × 5 cm\" readonly class=\"form-control\">{% elsif page.handle contains 'clothing' %}<div class=\"size-buttons\" role=\"group\" aria-label=\"Select Size\"><button type=\"button\" class=\"size-option active\" data-size=\"S\" aria-pressed=\"true\">S</button><button type=\"button\" class=\"size-option\" data-size=\"M\" aria-pressed=\"false\">M</button><button type=\"button\" class=\"size-option\" data-size=\"L\" aria-pressed=\"false\">L</button><button type=\"button\" class=\"size-option\" data-size=\"XL\" aria-pressed=\"false\">XL</button><button type=\"button\" class=\"size-option\" data-size=\"2XL\" aria-pressed=\"false\">2XL</button></div><input type=\"hidden\" name=\"properties[Size]\" id=\"size-input\" value=\"S\">{% else %}<select name=\"properties[Size]\"><option value=\"2in x 2in\">2in x 2in</option><option value=\"3in x 3in\">3in x 3in</option></select>{% endif %}</div>\n      <div class=\"form-row\"><label class=\"row-label\">Select Format</label>{% if page.handle contains 'car-hanging' %}<select name=\"properties[Format]\"><option value=\"Acrylic\">Acrylic</option></select>{% elsif page.handle contains 'clothing' %}<select name=\"properties[Format]\"><option value=\"Regular Fit\">Regular Fit</option></select>{% else %}<select name=\"properties[Format]\"><option value=\"Premium Vinyl\">Premium Vinyl</option><option value=\"Reflective Vinyl\">Reflective Vinyl</option></select>{% endif %}</div>\n      <div class=\"form-row production-row\"><label class=\"row-label\">Production</label><div class=\"production-buttons\" role=\"group\" aria-label=\"Production time\"><button type=\"button\" class=\"production-option active\" data-production=\"Standard\" aria-pressed=\"true\">Standard</button><button type=\"button\" class=\"production-option\" data-production=\"Priority\" aria-pressed=\"false\">Priority</button></div><input type=\"hidden\" name=\"properties[Production]\" id=\"production-input\" value=\"Standard\"></div>\n      <div class=\"form-row\"><label class=\"row-label\">Upload Design</label><input type=\"file\" id=\"custom-image-upload\" name=\"properties[_Uploaded Design]\" accept=\"image/*\" required></div>\n      <div id=\"inline-preview-container\" class=\"inline-preview\"><img id=\"inline-preview-image\" src=\"\" style=\"max-width:100%; border-radius:4px;\"></div>\n      <div class=\"product-actions\">\n        <div class=\"quantity-wrapper\">\n          <button type=\"button\" class=\"qty-btn\" id=\"qty-minus\">&minus;</button>\n          <input type=\"number\" class=\"qty-input\" name=\"quantity\" id=\"qty-input\" min=\"1\" value=\"1\">\n          <button type=\"button\" class=\"qty-btn\" id=\"qty-plus\">+</button>\n        </div>\n        <button type=\"submit\" class=\"add-to-cart-btn\">ADD TO CART</button>\n      </div>\n    </form>\n  </div>\n</div>\n\n<script>\n(function() {\n  console.log(\"Custom page JS loaded\");\n  console.log(\"Product variants:\", [\n    {% for variant in product.variants %}\n      {\n        id: {{ variant.id }},\n        title: {{ variant.title | json }},\n        price: {{ variant.price | json }}\n      }{% unless forloop.last %},{% endunless %}\n    {% endfor %}\n  ]);\n\n  // 1. UPLOAD PREVIEW\n  const fileInput = document.getElementById('custom-image-upload');\n  if (fileInput) {\n    fileInput.addEventListener('change', function(e) {\n      const reader = new FileReader();\n      reader.onload = (ev) => {\n        document.getElementById('inline-preview-image').src = ev.target.result;\n        document.getElementById('inline-preview-container').style.display = 'block';\n      };\n      reader.readAsDataURL(e.target.files[0]);\n    });\n  }\n\n  const productionButtons = document.querySelectorAll('.production-option');\n  const productionInput = document.getElementById('production-input');\n  if (productionButtons.length > 0 && productionInput) {\n    productionButtons.forEach(button => {\n      button.addEventListener('click', () => {\n        productionButtons.forEach(btn => {\n          const isSelected = btn === button;\n          btn.classList.toggle('active', isSelected);\n          btn.setAttribute('aria-pressed', String(isSelected));\n        });\n        productionInput.value = button.dataset.production;\n      });\n    });\n  }\n\n  // 1.5 SIZE SELECTION FOR CLOTHING\n  const sizeButtons = document.querySelectorAll('.size-option');\n  const sizeInput = document.getElementById('size-input');\n  if (sizeButtons.length > 0 && sizeInput) {\n    sizeButtons.forEach(button => {\n      button.addEventListener('click', () => {\n        sizeButtons.forEach(btn => {\n          const isSelected = btn === button;\n          btn.classList.toggle('active', isSelected);\n          btn.setAttribute('aria-pressed', String(isSelected));\n        });\n        sizeInput.value = button.dataset.size;\n        console.log(\"Selected Size:\", sizeInput.value);\n      });\n    });\n  }\n\n  // 2. FORM NATIVE POST, VALIDATION, AND LOGS\n  const qtyMinus = document.getElementById('qty-minus');\n  const qtyPlus = document.getElementById('qty-plus');\n  const qtyInput = document.getElementById('qty-input');\n  if (qtyMinus && qtyPlus && qtyInput) {\n    qtyMinus.addEventListener('click', () => {\n      let val = parseInt(qtyInput.value) || 1;\n      if (val > 1) qtyInput.value = val - 1;\n    });\n    qtyPlus.addEventListener('click', () => {\n      let val = parseInt(qtyInput.value) || 1;\n      qtyInput.value = val + 1;\n    });\n  }\n\n  const productForm = document.getElementById('product-form');\n  const hiddenVariantIdInput = document.getElementById('hidden-variant-id');\n  if (productForm) {\n    productForm.addEventListener('submit', function(e) {\n      const variantId = hiddenVariantIdInput ? hiddenVariantIdInput.value : '';\n      if (!variantId) {\n        e.preventDefault();\n        alert('Error: No variant ID found.');\n        return;\n      }\n      if (isNaN(variantId)) {\n        e.preventDefault();\n        alert('Error: Selected variant ID is not numeric.');\n        return;\n      }\n\n      console.log(\"Selected variant ID:\", variantId);\n\n      const formData = new FormData(productForm);\n      console.log(\"FormData entries:\");\n      for (let pair of formData.entries()) {\n        console.log(pair[0] + ': ' + pair[1]);\n      }\n      if (window.location.hostname === '127.0.0.1' || window.location.hostname === 'localhost') {\n        productForm.action = 'https://thelogoman-2.myshopify.com/cart/add';\n      }\n    });\n  }\n\n  // 3. AGGRESSIVE CART INJECTION\n  function fixCartImages() {\n    const elements = document.querySelectorAll('a, span, dd');\n    elements.forEach(el => {\n      const content = el.innerText || el.textContent;\n      const isImageFile = /\\.(jpg|jpeg|png|gif|webp)/i.test(content);\n      const isShopifyLink = el.tagName === 'A' && el.href.includes('/uploads/');\n\n      if (isImageFile || isShopifyLink) {\n        if (el.dataset.fixed === \"true\") return;\n        el.dataset.fixed = \"true\";\n\n        const imageUrl = el.tagName === 'A' ? el.href : content.trim();\n        if (imageUrl.includes('http') || imageUrl.includes('/uploads/')) {\n          const img = document.createElement('img');\n          img.src = imageUrl;\n          img.style.cssText = \"width:100px; height:100px; object-fit:cover; border-radius:8px; border:1px solid #444; display:block; margin-top:8px;\";\n          el.innerHTML = ''; \n          el.appendChild(img);\n        }\n      }\n    });\n  }\n\n  fixCartImages();\n  const observer = new MutationObserver(fixCartImages);\n  observer.observe(document.body, { childList: true, subtree: true });\n})();\n</script>"
      }
    }
