    "custom_liquid_NUyBHY": {
      "type": "custom-liquid",
      "custom_css": [],
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "{% style %}\n\n/* ================= DESKTOP ================= */\n@media (min-width:1150px){\n  .collection-grid{position:relative;}\n  .collection-grid__wrapper{\n    display:flex!important;\n    justify-content:space-between;\n    padding:25px 30%!important;\n    position:absolute;\n    top:0;left:0;width:100%;\n    z-index:3;\n    background:transparent!important;\n  }\n  .collection-grid__cards{\n    flex:0 0 20%;\n    text-align:center;\n    background:transparent!important;\n  }\n  .collection-grid__cards h3{\n    font-size:12px!important;\n    color:#fff!important;\n  }\n}\n\n/* ================= MOBILE ONLY ================= */\n@media (max-width:480px){\n\n  /* Collection grid overlay */\n  .collection-grid{\n    position:absolute!important;\n    top:0;\n    left:0;\n    width:100%;\n    z-index:3;\n    background:transparent!important;\n    overflow:hidden!important;\n  }\n\n  /* Horizontal touch slider */\n  .collection-grid__wrapper{\n    display:flex!important;\n    flex-wrap:nowrap!important;\n    gap:10px!important;\n    padding:12px 16px!important;\n    background:transparent!important;\n    position:static!important;\n    width:auto!important;\n    overflow-x:auto!important;\n    overflow-y:hidden!important;\n    -webkit-overflow-scrolling:touch;\n    scrollbar-width:none;\n    scroll-snap-type:x mandatory;\n    scroll-behavior:smooth;\n    overscroll-behavior-x:contain;\n    touch-action:pan-x;\n  }\n\n  .collection-grid__wrapper::-webkit-scrollbar{\n    display:none;\n  }\n\n  /* Show 3 icons */\n  .collection-grid__cards{\n    flex:0 0 calc((100% - 32px)/3)!important;\n    min-width:calc((100% - 32px)/3)!important;\n    scroll-snap-align:start;\n    text-align:center;\n    background:transparent!important;\n  }\n\n  /* Remove default card spacing */\n  .collection-card{\n    display:flex!important;\n    flex-direction:column;\n    gap:0!important;\n    padding-bottom:0!important;\n  }\n\n  /* Icon size */\n  .collection-grid__cards img,\n  .collection-grid__cards svg{\n    width:80px!important;\n    height:80px!important;\n    border-radius:50%;\n    object-fit:cover;\n    margin:0 auto;\n  }\n\n  /* Collection titles */\n  .collection-grid__cards h3,\n  .collection-card__title{\n    font-size:10px!important;\n    line-height:1!important;\n    color:#fff!important;\n    text-transform:uppercase;\n    margin-top:6px!important;\n    letter-spacing:.5px!important;\n  }\n\n  /* Hero section */\n  .hero,\n  .banner,\n  .slideshow{\n    min-height:700px!important;\n    height:700px!important;\n    padding-top:0!important;\n    padding-bottom:0!important;\n    background-position:center top!important;\n    overflow:hidden!important;\n  }\n\n  /* Hero wrapper */\n  .hero__wrapper,\n  .hero_wrapper{\n    --slide-height:700px;\n    height:700px!important;\n    min-height:700px!important;\n  }\n\n  /* Hero media containers */\n  .hero__media,\n  .hero__image,\n  .hero picture,\n  .banner picture{\n    width:100%!important;\n    height:100%!important;\n    min-height:700px!important;\n    overflow:hidden!important;\n  }\n\n  /* Hero background image with slow zoom animation */\n  .hero img,\n  .banner img,\n  .slideshow img{\n    width:100%!important;\n    height:100%!important;\n    min-height:700px!important;\n    object-fit:cover!important;\n    object-position:center center!important;\n    transform:scale(1.25);\n    transform-origin:center center;\n    animation:heroZoomMobile 12s ease-in-out infinite alternate;\n    will-change:transform;\n  }\n\n  @keyframes heroZoomMobile{\n    from{transform:scale(1.15);}\n    to{transform:scale(1.30);}\n  }\n\n  /* Hero text position */\n  .hero__wrapper .hero__content,\n  .hero_wrapper .hero_content{\n    padding-top:320px!important;\n    padding-bottom:0!important;\n    display:block!important;\n    position:relative;\n    z-index:2;\n    max-width:100%!important;\n  }\n\n  /* Remove section spacing around hero */\n  .shopify-section.hero-section.spaced-section,\n  .hero-section.spaced-section{\n    padding-top:0!important;\n    padding-bottom:0!important;\n  }\n\n  /* Add space above next section */\n  .hero-section + .spaced-section,\n  .hero + .spaced-section,\n  .shopify-section.hero-section + .shopify-section{\n    padding-top:40px!important;\n  }\n}\n\n{% endstyle %}"
      }
