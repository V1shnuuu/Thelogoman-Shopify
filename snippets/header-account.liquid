{% liquid
  assign is_mobile = is_mobile | default: false
%}  

{%- if shop.customer_accounts_enabled and settings.enable_account_btn -%}
    <div class="header__account {% if is_mobile %}header__account--mobile container{% endif %}">
      {% if settings.enable_account_modal_component %}
        <shopify-account
          menu="{{ settings.customer_account_menu | default: "customer-account-main-menu" }}"
          style="display: flex; align-items: center;"
        >
          <div slot="signed-out-avatar">
              {% if is_mobile != true %}
                {%- if request.page_type != 'customers/account' and settings.account_type == 'drawer' -%}
									<details>
										<summary class="header__icon header__icon--account header__icon--summary focus-inset modal__toggle" 
											aria-haspopup="dialog" 
											role="button"
											id="account-icon-open"
										>
											{% comment %}{% render 'icon-account' %}{% endcomment %}
											<span class="header-tabs">
												{% if settings.account_button_type == 'icon' or settings.account_button_type == 'text_and_icon'%}
													{% render 'icon-account' %}
												{% endif %}
												{% if settings.account_button_type == 'text' or settings.account_button_type == 'text_and_icon'%}	
													{{- 'general.account.title' | t -}}
												{% endif %}
											</span>
										</summary>
									</details>
								{%- else -%}
									<div class="header__icon header__icon--account header__icon--summary focus-inset modal__toggle"
										>
										<span class="header-tabs">
											{% if settings.account_button_type == 'icon' or settings.account_button_type == 'text_and_icon'%}
												{% render 'icon-account' %}
											{% endif %}
											{% if settings.account_button_type == 'text' or settings.account_button_type == 'text_and_icon'%}	
												{{- 'general.account.title' | t -}}
											{% endif %}
										</span>
									</div>
								 {%- endif -%}
              {% else %}
                <div class="button button--primary menu-drawer__account focus-inset">
                  <span class="button-label">
                  {%- liquid
                    if customer
                      echo 'customer.account_fallback' | t
                    else
                      echo 'customer.log_in' | t
                    endif -%}
                  </span>
                </div>
               {% endif %}   
          </div>
        </shopify-account>
      {%- else -%}
        {% liquid
          if customer
            assign btn_link = routes.account_profile_url
            assign btn_aria = 'customer.account_fallback' | t
          else
            assign btn_link = routes.account_login_url
            assign btn_aria = 'customer.log_in' | t
          endif
        %}

        {% if is_mobile != true %}
          {%- if settings.account_type == 'drawer' -%}
            <a
              href="#"
              id="account-icon-open"
              class="header__icon header__icon--account header__icon--summary focus-inset modal__toggle js-account-modal-trigger"
            >
              <span class="header-tabs">
                {% if settings.account_button_type == 'icon' or settings.account_button_type == 'text_and_icon' %}
                  {% render 'icon-account' %}
                {% endif %}
                {% if settings.account_button_type == 'text' or settings.account_button_type == 'text_and_icon' %}
                  {{- 'general.account.title' | t -}}
                {% endif %}
              </span>
            </a>
          {%- else -%}
            <a
              class="header__icon header__icon--account header__icon--summary focus-inset modal__toggle"
              href="{{ btn_link }}"
              aria-label="{{ btn_aria }}"
            >
              <span class="header-tabs">
                {% if settings.account_button_type == 'icon' or settings.account_button_type == 'text_and_icon' %}
                  {% render 'icon-account' %}
                {% endif %}
                {% if settings.account_button_type == 'text' or settings.account_button_type == 'text_and_icon' %}
                  {{- 'general.account.title' | t -}}
                {% endif %}
              </span>
            </a>
          {%- endif -%}
        {% else %}
          {%- if customer -%}
            <div class="menu-drawer__utility-account">
              <div class="menu-drawer__utility-account-header">
                <a class="menu-drawer__utility-name link button button--simple" href="{{ routes.account_profile_url }}">{{ customer.name }}</a>
                <a class="menu-drawer__utility-logout" href="{{ routes.account_logout_url }}">{{ 'customer.log_out' | t }}</a>
              </div>
            </div>
          {%- else -%}
            <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="button button--primary menu-drawer__account focus-inset">
              <span class="button-label">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo 'customer.log_in' | t
                endif -%}
              </span>
            </a>
          {%- endif -%}
        {% endif %}

      {%- endif -%}
    </div>
  {%- endif -%}
