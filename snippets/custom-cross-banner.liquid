  <h2 class="cross-banner-heading">Explore Other Custom Products</h2>
  <div class="cross-banner-grid">
    
    {%- unless current_handle contains 'automotive' -%}
      <a href="/pages/custom-3d-automotive-stickers" class="cross-banner-card">
