<style>
/* Other Custom Products Banner Styling */
.custom-cross-banner-section {
  max-width: 1400px;
  margin: 60px auto 40px;
  padding: 0 20px;
  clear: both;
}

.cross-banner-heading {
  font-size: 28px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 35px;
  color: inherit;
  position: relative;
  display: inline-block;
}

.cross-banner-heading::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -6px;
  width: 60px;
  height: 3px;
  background-color: #00E676; /* Accent theme color */
  border-radius: 2px;
}

.cross-banner-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.cross-banner-card {
  display: block;
  position: relative;
  aspect-ratio: 4 / 5;
  background-color: #121212;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.08);
  text-decoration: none;
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease;
}

/* Adapt box shadow for lighter themes or non-dark sections */
.custom-automotive-stickers ~ .custom-cross-banner-section .cross-banner-card {
  border: 1px solid rgba(0, 0, 0, 0.08);
  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
}

.cross-banner-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.6);
  border-color: rgba(255, 255, 255, 0.2);
}

.custom-automotive-stickers ~ .custom-cross-banner-section .cross-banner-card:hover {
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
  border-color: rgba(0, 0, 0, 0.15);
}

.cross-banner-image-wrapper {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

.cross-banner-image-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

.cross-banner-card:hover .cross-banner-image-wrapper img {
  transform: scale(1.06);
}

.cross-banner-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.4) 60%, rgba(0, 0, 0, 0) 100%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.cross-banner-category {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: #00E676;
  margin-bottom: 6px;
}

.cross-banner-title {
  font-size: 20px;
  font-weight: 800;
  color: #ffffff;
  margin: 0 0 10px;
  line-height: 1.2;
  letter-spacing: -0.5px;
}

.cross-banner-cta {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
  opacity: 0.85;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: opacity 0.3s ease;
}

.cross-banner-cta .arrow {
  display: inline-block;
  transition: transform 0.3s ease;
}

.cross-banner-card:hover .cross-banner-cta {
  opacity: 1;
}

.cross-banner-card:hover .cross-banner-cta .arrow {
  transform: translateX(4px);
}

@media (max-width: 990px) {
  .cross-banner-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .cross-banner-heading {
    font-size: 24px;
    margin-bottom: 25px;
  }
  .cross-banner-content {
    padding: 16px;
  }
  .cross-banner-title {
    font-size: 18px;
    margin-bottom: 6px;
  }
}

@media (max-width: 480px) {
  .cross-banner-grid {
    grid-template-columns: 1fr;
    gap: 16px;
  }
}
</style>

{%- assign current_handle = page.handle -%}
