          <img src="{{ 'custom-clothing.jpg' | asset_img_url: '600x600' }}" alt="Custom Clothing & Accessories" loading="lazy">
        </div>
        <div class="cross-banner-content">
          <span class="cross-banner-category">Custom Clothing</span>
          <h3 class="cross-banner-title">Clothing & Accessories</h3>
